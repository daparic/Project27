# Let git decide text vs binary for anything not listed below.
* text=auto

# ---- Source & config text files: store LF, checkout CRLF on Windows ----
*.cpp           text eol=crlf
*.h             text eol=crlf
*.hpp           text eol=crlf
*.c             text eol=crlf
*.cs            text eol=crlf
*.json          text eol=crlf
*.md            text eol=crlf
*.gitignore     text eol=crlf
*.gitattributes text eol=crlf

# ---- Visual Studio project files ----
*.sln           text eol=crlf
*.slnx          text eol=crlf
*.vcxproj       text eol=crlf
*.vcxproj.filters text eol=crlf
*.props         text eol=crlf
*.targets       text eol=crlf

# ---- Binary files: never touch line endings ----
*.exe           binary
*.dll           binary
*.lib           binary
*.obj           binary
*.pdb           binary
*.ilk           binary
*.ipch          binary
*.db            binary
*.suo           binary
*.vsidx         binary
