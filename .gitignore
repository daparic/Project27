# -----------------------------------------------------------------------
# Visual Studio IDE state
# -----------------------------------------------------------------------
# Local solution cache, IntelliSense DB, Copilot indices,
# precompiled-header cache (*.ipch can exceed 100 MB), document layout,
# and solution user options. All regenerated on next VS open.
.vs/

# -----------------------------------------------------------------------
# Per-user project settings
# -----------------------------------------------------------------------
# Stores each developer's local debug working directory, environment
# variables, and debugger settings. Must not be shared.
*.vcxproj.user

# -----------------------------------------------------------------------
# MSBuild / VS build output trees
# -----------------------------------------------------------------------
x64/
x86/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublicRelease/

# -----------------------------------------------------------------------
# Compiled output — executables and libraries
# -----------------------------------------------------------------------
*.exe
*.dll
*.lib
*.exp

# -----------------------------------------------------------------------
# Linker / compiler intermediates
# -----------------------------------------------------------------------
*.obj
*.o
*.ilk
*.ipch

# -----------------------------------------------------------------------
# Debug symbols
# -----------------------------------------------------------------------
*.pdb

# -----------------------------------------------------------------------
# MSBuild artefacts
# -----------------------------------------------------------------------
*.recipe
*.FileListAbsolute.txt

# -----------------------------------------------------------------------
# Log files
# -----------------------------------------------------------------------
*.log
